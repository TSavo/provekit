{
  "name": "provekit",
  "version": "0.4.0",
  "description": "ProvekIt: the fourth horseman of the git commit. tsc, lint, test, prove.",
  "main": "./lib/provekit.cjs",
  "types": "./src/index.ts",
  "bin": {
    "provekit": "bin/provekit.cjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./lib/provekit.mjs",
      "require": "./lib/provekit.cjs",
      "default": "./lib/provekit.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin/",
    "lib/",
    "src/",
    "drizzle/",
    ".provekit/principles/",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "vitest run",
    "fuzz": "ts-node --esm scripts/fuzz.ts"
  },
  "keywords": [
    "verification",
    "formal-verification",
    "z3",
    "smt",
    "static-analysis",
    "ci",
    "pre-commit",
    "invariants"
  ],
  "homepage": "https://github.com/provekit/provekit",
  "repository": {
    "type": "git",
    "url": "https://github.com/provekit/provekit.git"
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.107",
    "@anthropic-ai/sdk": "^0.88.0",
    "@opencode-ai/sdk": "^1.4.3",
    "@types/node": "^25.6.0",
    "@wopr-network/better-prompts": "^0.1.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "handlebars": "^4.7.9",
    "pino": "^10.3.1",
    "pino-abstract-transport": "^3.0.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/pino": "^7.0.4",
    "@vitest/ui": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "fast-check": "^4.7.0",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
