# Bridgeworks red mutation: XOR replaced by OR.
# bridgeworks:claim gates.full_adder.equations
# bridgeworks:mutation expected_refusal=gates_xor_replaced_by_or

.model bridgeworks_full_adder_mut_xor_or
.inputs a b cin
.outputs sum cout

# axb is incorrectly OR, not XOR.
.names a b axb
1- 1
-1 1

.names axb cin sum
01 1
10 1

.names a b cin cout
11- 1
1-1 1
-11 1

.end
