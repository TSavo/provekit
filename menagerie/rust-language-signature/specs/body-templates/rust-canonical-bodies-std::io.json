        {
          "concept_name": "concept:stdio-read-line",
          "emission_template": {
            "kind": "verbatim",
            "template": "let stdin = io::stdin();\n    let mut handle = stdin.lock();\n    let mut line = String::new();\n    match handle.read_line(&mut line) {\n        Ok(0) => None,\n        Ok(_) => {\n            if line.ends_with('\\n') {\n                line.pop();\n                if line.ends_with('\\r') {\n                    line.pop();\n                }\n            }\n            Some(line)\n        }\n        Err(_) => None,\n    }"
          },
          "loss_record_contribution": {
            "form": "literal",
            "value": {
              "entries": []
            }
          },
          "signature_guard": {
