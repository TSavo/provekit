            "min_params": 0
          },
          "target_library_tag": "std::io"
        },
        {
          "concept_name": "concept:stdio-write-line",
          "emission_template": {
            "kind": "verbatim",
            "template": "let stdout = io::stdout();\n    let mut handle = stdout.lock();\n    let _ = writeln!(handle, \"{}\", ${param0});\n    let _ = handle.flush();"
          },
