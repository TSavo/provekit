#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
usage: bcargo [bcargo options] [cargo args...]

Sync the Rust-facing Sugar workspace to battleaxe, then run Cargo there.

Options:
  --sync-bin NAME     After a successful cargo command, copy target/<profile>/NAME
                      back to the matching local target directory. Repeatable.
  --sync-bins LIST    Comma-separated form of --sync-bin.

Environment:
  BCARGO_REMOTE_HOST   SSH host alias to use (default: battleaxe)
  BCARGO_REMOTE_ROOT   Remote scratch root (default: /home/tsavo/remote/sugar-bcargo)
  BCARGO_PYTHON_ENV    Set to 0 to skip remote Python kit env provisioning
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

sync_bins=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --sync-bin)
      if [[ $# -lt 2 ]]; then
        echo "bcargo: --sync-bin requires a binary name" >&2
        exit 2
      fi
      sync_bins+=("$2")
      shift 2
      ;;
    --sync-bins)
      if [[ $# -lt 2 ]]; then
        echo "bcargo: --sync-bins requires a comma-separated list" >&2
        exit 2
      fi
      IFS=',' read -r -a parsed_sync_bins <<<"$2"
      for bin in "${parsed_sync_bins[@]}"; do
        [[ -n "$bin" ]] && sync_bins+=("$bin")
      done
      shift 2
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done
cargo_args=("$@")

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$repo_root" ]]; then
  echo "bcargo: must be run from inside a git checkout" >&2
  exit 2
fi
repo_root="$(cd "$repo_root" && pwd -P)"
local_cwd="$(pwd -P)"

case "$local_cwd" in
  "$repo_root")
    rel_cwd=""
    ;;
  "$repo_root"/*)
    rel_cwd="${local_cwd#"$repo_root"/}"
    ;;
  *)
    echo "bcargo: current directory is outside $repo_root" >&2
    exit 2
    ;;
esac

remote_host="${BCARGO_REMOTE_HOST:-battleaxe}"
# Per-checkout remote root so concurrent worktrees/agents do not clobber each
# other. All checkouts previously shared one root, and `rsync -az --delete`
# from one wiped another's source mid-build (stale/false builds, stalls). Derive
# a stable suffix from the absolute checkout path so each worktree gets its own
# remote scratch; the shared sccache cache still gives cross-checkout reuse.
_bcargo_root_tag="$(printf '%s' "$repo_root" | shasum 2>/dev/null | cut -c1-12)"
_bcargo_root_tag="${_bcargo_root_tag:-default}"
remote_root="${BCARGO_REMOTE_ROOT:-/home/tsavo/remote/sugar-bcargo-${_bcargo_root_tag}}"
remote_repo="$remote_root/sugar"
remote_python_venv="$remote_root/python-kit-env"
remote_python_bin="$remote_python_venv/bin"
remote_python="$remote_python_bin/python"
provision_python_env="${BCARGO_PYTHON_ENV:-1}"
ssh_bin="${BCARGO_SSH:-ssh}"
rsync_bin="${BCARGO_RSYNC:-rsync}"

quote_sh() {
  printf "'"
  printf "%s" "$1" | sed "s/'/'\\\\''/g"
  printf "'"
}

remote_parent() {
  local path="$1"
  dirname "$path"
}

abs_from_cwd() {
  local path="$1"
  if [[ "$path" == /* ]]; then
    printf '%s\n' "$path"
  else
    printf '%s\n' "$local_cwd/$path"
  fi
}

remote_for_local_path() {
  local path="$1"
  case "$path" in
    "$repo_root")
      printf '%s\n' "$remote_repo"
      ;;
    "$repo_root"/*)
      printf '%s/%s\n' "$remote_repo" "${path#"$repo_root"/}"
      ;;
    *)
      printf '%s\n' "$path"
      ;;
  esac
}

run_ssh() {
  "$ssh_bin" -o BatchMode=yes "$remote_host" "$@"
}

exclude_args=(
  --exclude='target/'
  --exclude='.git/'
  --exclude='.jj/'
  --exclude='.worktrees/'
  --exclude='.claude/'
  --exclude='.ruff_cache/'
  --exclude='.venv-test-rust/'
  --exclude='.understand-anything/'
  --exclude='node_modules/'
  --exclude='bazel-bin'
  --exclude='bazel-out'
  --exclude='bazel-sugar'
  --exclude='bazel-testlogs'
  --exclude='sugar-warnings/'
  --exclude='sugar-worktrees/'
  --exclude='.sugar/runs/'
  --exclude='.sugar/witnesses/'
  # NOTE: `.sugar/lift/` is intentionally NOT excluded. Those are the
  # hand-authored per-project lift manifests (tiny TOMLs naming the plugin
  # commands) that `sugar mint` needs; excluding them made remote mint
  # impossible. Only the generated `runs/` and `witnesses/` outputs are skipped.
)

sync_dir() {
  local rel_path="$1"
  local local_path="$repo_root/$rel_path"
  local remote_path="$remote_repo/$rel_path"

  [[ -d "$local_path" ]] || return 0
  run_ssh "mkdir -p $(quote_sh "$(remote_parent "$remote_path")")"
  "$rsync_bin" -az --delete "${exclude_args[@]}" "$local_path/" "$remote_host:$remote_path/"
}

sync_file() {
  local rel_path="$1"
  local local_path="$repo_root/$rel_path"
  local remote_path="$remote_repo/$rel_path"

  [[ -f "$local_path" ]] || return 0
  run_ssh "mkdir -p $(quote_sh "$(remote_parent "$remote_path")")"
  "$rsync_bin" -az "$local_path" "$remote_host:$remote_path"
}

remove_remote_dir() {
  local rel_path="$1"
  local remote_path="$remote_repo/$rel_path"

  run_ssh "rm -rf $(quote_sh "$remote_path")"
}

sync_file Cargo.toml
sync_file Cargo.lock
sync_file Makefile
sync_file package.json
sync_file pnpm-lock.yaml
sync_file rust-toolchain
sync_file rust-toolchain.toml
# Repo-root workspace config and hand-authored plugin manifests. Generated
# `.sugar/` outputs (runs/, witnesses/, cache/, baselines/, etc.) stay out
# of the remote copy, but lift/realize manifests are source inputs for CLI
# dispatch and must travel with bcargo.
sync_file .sugar/config.toml
sync_dir .sugar/lift
sync_dir .sugar/realize

sync_dir implementations/rust
sync_dir implementations/python
sync_dir implementations/go
sync_dir implementations/java
sync_dir examples
remove_remote_dir menagerie
sync_dir menagerie/csharp-language-signature/specs
sync_dir menagerie/python-language-signature/specs
sync_dir tools
sync_dir protocol
sync_dir docs/self-application
sync_dir scripts
sync_dir bootstrap
sync_dir conformance
sync_dir tests

remote_cwd="$remote_repo"
if [[ -n "$rel_cwd" ]]; then
  remote_cwd="$remote_repo/$rel_cwd"
fi

profile="debug"
manifest_path=""
target_dir_arg=""
for ((i = 0; i < ${#cargo_args[@]}; i++)); do
  arg="${cargo_args[$i]}"
  case "$arg" in
    --release)
      profile="release"
      ;;
    --manifest-path)
      if (( i + 1 < ${#cargo_args[@]} )); then
        manifest_path="${cargo_args[$((i + 1))]}"
      fi
      ;;
    --manifest-path=*)
      manifest_path="${arg#--manifest-path=}"
      ;;
    --target-dir)
      if (( i + 1 < ${#cargo_args[@]} )); then
        target_dir_arg="${cargo_args[$((i + 1))]}"
      fi
      ;;
    --target-dir=*)
      target_dir_arg="${arg#--target-dir=}"
      ;;
  esac
done

if [[ -n "$target_dir_arg" ]]; then
  local_target_dir="$(abs_from_cwd "$target_dir_arg")"
  remote_target_dir="$(remote_for_local_path "$local_target_dir")"
elif [[ -n "$manifest_path" ]]; then
  local_manifest_path="$(abs_from_cwd "$manifest_path")"
  local_target_dir="$(dirname "$local_manifest_path")/target"
  remote_target_dir="$(remote_for_local_path "$local_target_dir")"
else
  local_target_dir="$local_cwd/target"
  remote_target_dir="$remote_cwd/target"
fi

remote_args=()
for arg in "$@"; do
  if [[ "$arg" == "$repo_root" ]]; then
    arg="$remote_repo"
  elif [[ "$arg" == "$repo_root"/* ]]; then
    arg="$remote_repo/${arg#"$repo_root"/}"
  fi
  remote_args+=("$(quote_sh "$arg")")
done

provision_steps=()
cargo_env=()
path_prefix="$remote_target_dir/$profile"
if [[ "$provision_python_env" != "0" ]]; then
  provision_steps+=("BCARGO_PYTHON_VENV=$(quote_sh "$remote_python_venv") make --quiet bcargo-python-kit-env")
  cargo_env+=("PYTHON=$(quote_sh "$remote_python")")
  path_prefix="$path_prefix:$remote_python_bin"
fi
cargo_env+=("PATH=$(quote_sh "$path_prefix"):\$PATH")

if ((${#provision_steps[@]} == 0)); then
  inner="cd $(quote_sh "$remote_cwd") && "
  for assignment in "${cargo_env[@]}"; do
    inner+="$assignment "
  done
  inner+="exec cargo"
else
  inner="cd $(quote_sh "$remote_repo")"
  for step in "${provision_steps[@]}"; do
    inner+=" && $step"
  done
  inner+=" && cd $(quote_sh "$remote_cwd") && "
  for assignment in "${cargo_env[@]}"; do
    inner+="$assignment "
  done
  inner+="exec cargo"
fi
for arg in "${remote_args[@]}"; do
  inner+=" $arg"
done

set +e
run_ssh "bash -lc $(quote_sh "$inner")"
status=$?
set -e

if [[ "$status" -ne 0 ]]; then
  exit "$status"
fi

if ((${#sync_bins[@]} > 0)); then
  for bin in "${sync_bins[@]}"; do
    remote_bin="$remote_target_dir/$profile/$bin"
    local_bin="$local_target_dir/$profile/$bin"
    mkdir -p "$(dirname "$local_bin")"
    "$rsync_bin" -az "$remote_host:$remote_bin" "$local_bin"
  done
fi
