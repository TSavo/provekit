'\"' {\u000a            out.push_str(\"\\\\\\\"\");\u000a        } else if c == '\\\\' {\u000a            out.push_str(\"\\\\\\\\\");\u000a        } else if (c as u32) < 0x20 {\u000a            const HEX: &[u8; 16] = b\"0123456789abcdef\";\u000a            let n = c as u32;\u000a            out.push_str(\"\\\\u00\");\u000a            out.push(HEX[((n >> 4) & 0xF) as usize] as char);\u000a            out.push(HEX[(n & 0xF) as usize] as char);\u000a        } else {\u000a            out.push(c);\u000a        }\u000a    }\u000a    out.push('\"');","file":"src/lib.rs","source_cid":"blake3-512:ac82f0f1c4d366994bb006e7832ba814d4aa482fdd9581467b4c3be7fdcf771ec44656f97264e6d368a737773237a4bf8d9b2dcba197d84f16639ea1f553eb41","span":{"end_col":1,"end_line":110,"start_col":0,"start_line":92}},"concept_name":"concept:rfc8785-jcs-encode-string","family":"concept:family:json-canonicalization","kind":"library-sugar-binding-entry","library_version":"0.1","loss_record_contribution":{"form":"literal","value":{"entries":[]}},"operand_bindings":[{"position":[0,0],"symbol":"out"},{"position":[2,0],"symbol":"out"}],"param_names":["s","out"],"param_types":["&str","&mutString"],"return_type":"()","signature_shape_cid":"blake3-512:03a93ea0145c24214cbbbfecae931db00884561946259720e38679377717c6f2237f4869a684c235b7f1b7ba55f9fc64662431fa5c634246ab4db4223e6e441f","source_function_name":"encode_string","target_language":"rust","target_library_tag":"provekit-shim-rfc8785-jcs-rust","term_shape":{"args":[{"args":[{},{"kind":"method","text":"push"},{"args":[],"concept_name":"concept:literal","op_cid":"blake3-512:02804a0bdbd2d5d541544451f41ee8d0d340baf28f70bd5abf5844e87a96aedd7b5ab3453962754a020679cc8c6b3d1f4cf0336a7ad8118128d42ac667abf2d6","sort":"blake3-512:be8721d24849feb74c4721520bdba02d352a94f49253a627cd509127472aa1c47cbe99cb705cac4159b5365abcce0c9aaa4901fe67630827deb6be1f9daeea10","source_text":"'\"'"}],"concept_name":"concept:call","op_cid":"blake3-512:fa2fd7c6f33492f270282faf69a89e21bb9988d8d0d