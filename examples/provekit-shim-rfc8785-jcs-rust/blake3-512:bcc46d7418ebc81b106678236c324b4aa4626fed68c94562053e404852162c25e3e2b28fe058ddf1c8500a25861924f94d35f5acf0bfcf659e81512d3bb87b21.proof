ontribution":{"form":"literal","value":{"entries":[]}},"operand_bindings":[{"position":[0,0],"symbol":"out"},{"position":[1,1],"symbol":"v"}],"param_names":["v"],"param_types":["&Value"],"return_type":"String","signature_shape_cid":"blake3-512:b47df1d4fe061fac3401fa5b61248e3eff19a1d3a6c9af8c3ae93c616fb571613e5240636bf50edb824c02e25e423f21e4343767c6ee6514e58839a2b25f857a","source_function_name":"encode_jcs","target_language":"rust","target_library_tag":"serde_json","term_shape":{"args":[{"args":[{},{"args":[{"kind":"path","text":"String::new"}],"concept_name":"concept:call","op_cid":"blake3-512:fa2fd7c6f33492f270282faf69a89e21bb9988d8d0d9678d253c19aa00a977bf1158396b870f2160b718835c6189b51a97b848af8946d43e4244728f0b7e870c"}],"concept_name":"concept:assign","op_cid":"blake3-512:c92de23581656b0f75bdeff5efe428c33b0088c43f28a35fa50ad77b73f5e13f60078d66c22cfed80d7764224d5647522e92d18de9e8808a19ae31fc4b1b389a"},{"args":[{"kind":"path","text":"encode_value"},{},{}],"concept_name":"concept:call","op_cid":"blake3-512:fa2fd7c6f33492f270282faf69a89e21bb9988d8d0d9678d253c19aa00a977bf1158396b870f2160b718835c6189b51a97b848af8946d43e4244728f0b7e870c"}],"concept_name":"concept:seq","op_cid":"blake3-512:2f4f01ae873fcd3d57990ecd94e24caaa3ce1cbd5baf4347b21fe8625750bd4b30e2f92b8415e4595ec637d3aa7f511d42c006d587ee1cf5fe8b264df39f1504"},"term_shape_cid":"blake3-512:efb0a4b098a0debf1f139f6ac4b442c6aacb9ed007de3d8cd69b7e2b7c5067c7fb897c93ef5e4782db2b440a265fd7f74afa9387c8b76c3c18299e46c4c9bf7f"},"header":{"bodySourceCid":"blake3-512:2a5afa4edcf19201afafc0c6a8fa34fb1cfe8b28ab2476f1fcac112315992f6353b03b3b252c2474d9fca55b9414c23d43de0fe6c73d927f2b2aeff1ad164f34","conceptName":"concept:rfc8785-jcs-encode","kind":"library-sugar-binding-entry","signatureShapeCid":"blake3-512:b47df1d4fe061fac3401fa5b61248e3eff19a1d3a6c9af8c3ae93c616fb571613e5240636bf50edb824c02e25e423f21e4343767c6ee6514e58839a2b25f857a","targetLanguage":"rust","targetLibraryTag":"serde_json"},"schemaVersion":"1"}xŗblake3-512:a075ea8c83d1f386ac593fbe0a9f72af4fc2f14f8461aa5adb656ada0f425d702b2aa9513ea002d50ee16a2de775bf17a8d34ee6d47b18c76995c0ab81925784Y
Ö{"body":{"body_source":{"body_text":"match v {\u000a        Value::Null => out.push_str(\"null\"),\u000a        Value::Bool(true) => out.push_str(\"true\"),\u000a        Value::Bool(false) => out.push_str(\"false\"),\u000a        Value::Number(n) => out.push_str(&n.to_string()),\u000a        Value::String(s) => encode_string(s, out),\u000a        Value::Array(items) => {\u000a            out.push('[');\u000a            for (i, item) in items.iter().enumerate() {\u000a                if i > 0 {\u000a                    out.push(',');\u000a                }\u000a                encode_value(item, out);\u000a            }\u000a            out.push(']');\u000a        }\u000a        Value::Object(map) => {\u000a            let mut sorted: Vec<(&String, &Value)> = map.iter().collect();\u000a            sorted.sort_by(|a, b| a.0.cmp(b.0));\u000a            out.push('{');\u000a            for (i, (k, val)) in sorted.iter().enumerate() {\u000a                if i > 0 {\u000a                    out.push(',');\u000a                }\u000a                encode_string(k, out);\u000a                out.push(':');\u000a                encode_value(val, out);\u000a            }\u000a            out.push('}');\u000a        }\u000a    }","file":"src/lib.rs","source_cid":"blake3-512:754c2e7e13e8e2c730762ac339d00579911cbc68fe630e0fa28d7ab1ebd180b2d6a9484a911f075332cd01b17c95a5ab904cebff74548e3a69c1b151b565746e","span":{"end_col":1,"end_line":79,"start_col":0,"start_line":47}},"concept_name":"concept:rfc8785-jcs-encode-value","kind":"library-sugar-binding-entry","loss_record_contribution":{"form":"literal","value":{"entries":[]}},"operand_bindings":[],"param_names":["v","out"],"param_types":["&Value","&mutString"],"return_type":"()","signature_shape_cid":"blake3-512:2568eb80c2f1160db9dd9dbf24a9f155f9cd6ad69e42ebe9fc72ec1d5235105b38480ef2f9e9f187ac9d30c9b3419b96c87f99655c91bf0ee8fc4b24d1685574","source_function_name":"encode_value","target_language":"rust","target_library_tag":"provekit-shim-rfc8785-jcs-rust","term_shape":{},"term_shape_cid":"blake3-512:6e46dd10defc9b56c29a6ec56b508c21f54c08192194e4df25bf36f0c9c3c279088cac4d3eedacccba5f753d4c1bb923a1440e28cd2be2e9ba67158a42421faa"},"header":{"bodySourceCid":"blake3-512:754c2e7e13e8e2c730762ac339d00579911cbc68fe630e0fa28d7ab1ebd180b2d6a9484a911f075332cd01b17c95a5ab904cebff74548e3a69c1b151b565746e","conceptName":"concept:rfc8785-jcs-encode-value","kind":"library-sugar-binding-entry","signatureShapeCid":"blake3-512:2568eb80c2f1160db9dd9dbf24a9f155f9cd6ad69e42ebe9fc72ec1d5235105b38480ef2f9e9f187ac9d30c9b3419b96c87f99655c91bf0ee8fc4b24d1685574","targetLanguage":"rust","targetLibraryTag":"provekit-shim-rfc8785-jcs-rust"},"schemaVersion":"1"}xŗblake3-512:b4e87974c1d8c26c9d8df1ee1ab6e77699ffa82bae398a0bc1d13ceab814c97c67443022cbc8e914c2777fbaf5ce134c1842149a041ae10fda1ba1467687b369YX{"body":{"body_source":{"body_text":"out.push('\"');\u000a    for c in s.chars() {\u000a        if c == '\"' {\u000a            out.push_str(\"\\\\\\\"\");\u000a        } else if c == '\\\\' {\u000a            out.push_str(\"\\\\\\\\\");\u000a        } else if (c as u32) < 0x20 {\u000a            const HEX: &[u8; 16] = b\"0123456789abcdef\";\u000a            let n = c as u32;\u000a            out.push_str(\"\\\\u00\");\u000a            out.push(HEX[((n >> 4) & 0xF) as usize] as char);\u000a            out.push(HEX[(n & 0xF) as usize] as char);\u000a        } else {\u000a            out.push(c);\u000a        }\u000a    }\u000a    out.push('\"');","file":"src/lib.rs","source_cid":"blake3-512:ac82f0f1c4d366994bb006e7832ba814d4aa482fdd9581467b4c3be7fdcf771ec44656f97264e6d368a737773237a4bf8d9b2dcba197d84f16639ea1f553eb41","span":{"end_col":1,"end_line":104,"start_col":0,"start_line":86}},"concept_name":"concept:rfc8785-jcs-encode-string","kind":"library-sugar-binding-entry","loss_record_contribution":{"form":"literal","value":{"entries":[]}},"operand_bindings":[{"position":[0,0],"symbol":"out"},{"position":[1,0,0,0],"symbol":"c"},{"position":[1,0,1,0],"symbol":"out"},{"position":[1,0,1,2],"symbol":"\"\\\\\\\"\""},{"position":[1,0,2,0,0],"symbol":"c"},{"position":[1,0,2,1,0],"symbol":"out"},{"position":[1,0,2,1,2],"symbol":"\"\\\\\\\\\""},{"position":[1,0,2,2,0,1],"symbol":"32"},{"position":[1,0,2,2,1,0,0],"symbol":"n"},{"position":[1,0,2,2,1,1,0],"symbol":"out"},{"position":[1,0,2,2,1,1,2],"symbol":"\"\\\\u00\""},{"position":[1,0,2,2,1,2,0],"symbol":"out"},{"position":[1,0,2,2,1,3,0],"symbol":"out"},{"position":[1,0,2,2,2,0],"symbol":"out"},{"position":[1,0,2,2,2,2],"symbol":"c"},{"position":[2,0],"symbol":"out"}],"param_names":["s","out"],"param_types":["&str","&mutString"],"return_type":"()","signature_shape_cid":"blake3-512:03a93ea0145c24214cbbbfecae931db00884561946259720e38679377717c6f2237f4869a684c235b7f1b7ba55f9fc64662431fa5c634246ab4db4223e6e441f","source_function_name":"encode_string","target_language":"rust","target_library_tag":"provekit-shim-rfc8785-jcs-rust","term_shape":{"args":[{"args":[{},{"kind":"method","text":"push"},{}],"concept_name":"concept:call","op_cid":"blake3-512:fa2fd7c6f33492f270282faf69a89e21bb9988d8d0d9678d253c19aa00a977bf1158396b870f2160b718835c6189b51a97b848af8946d43e4244728f0b7e870c"},{"args":[{"args":[{"args":[{},{}],"concept_name":"concept:eq","op_cid":"blake3-512:6416cb7457c857c60cd901a01edddb95fed1cd8f890ab6a37c874edcdb7125e5308cfdba63247e84abde588e4f555ebdd4020f7362a3f7c8746bae338f57d522"},{"args":[{},{"kind":"method","text":"push_str"},{"args":[],"concept_name":"concept:literal","op_cid":"blake3-512:02804a0bdbd2d5d541544451f41ee8d0d340baf28f70bd5abf5844e87a96aedd7b5ab3453962754a020679cc8c6b3d1f4cf0336a7ad8118128d42ac667abf2d6","sort":"blake3-512:be8721d24849feb74c4721520bdba02d352a94f49253a627cd509127472aa1c47cbe99cb705cac4159b5365abcce0c9aaa4901fe67630827deb6be1f9daeea10","value":"\\\""}],"concept_name":"concept:call","op_cid":"blake3-512:fa2fd7c6f33492f270282faf69a89e21bb9988d8d0d9678d253c19aa00a977bf1158396b870f2160b718835c6189b51a97b848af8946d43e42