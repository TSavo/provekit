:family:json-canonicalization\",\u000a        version = \"0.1\",\u000a        loss = {}\u000a    )\u000a    public static void encode_string(String s, StringBuilder out) {\u000a        out.append('\"');\u000a        for (int i = 0; i < s.length(); i++) {\u000a            char c = s.charAt(i);\u000a            if (c == '\"') {\u000a                out.append(\"\\\\\\\"\");\u000a            } else if (c == '\\\\') {\u000a                out.append(\"\\\\\\\\\");\u000a            } else if (c == '\\b') {\u000a                out.append(\"\\\\b\");\u000a            } else if (c == '\\f') {\u000a                out.append(\"\\\\f\");\u000a            } else if (c == '\\n') {\u000a                out.append(\"\\\\n\");\u000a            } else if (c == '\\r') {\u000a                out.append(\"\\\\r\");\u000a            } else if (c == '\\t') {\u000a                out.append(\"\\\\t\");\u000a            } else if (c < 0x20) {\u000a                out.append(String.format(\"\\\\u%04x\", (int) c));\u000a            } else {\u000a                out.append(c);\u000a            }\u000a        }\u000a        out.append('\"');\u000a    }\u000a","file":"src/main/java/org/provekit/shim/rfc8785_jcs_java/RFC8785JcsShim.java","source_cid":"blake3-512:9e3c2e9ff7ce9ab3f281b4d7c248c6cc663e3af35bd9672dd2741a2f6b226fe879ba2bcbeb3daf69afaf8b99df087c4cff9d68ac0ab5ba12ac03860351853264","span":{"end_col":5,"end_line":144,"start_col":4,"start_line":112}},"concept_name":"concept:rfc8785-jcs-encode-string","family":"concept:family:json-canonicalization","kind":"library-sugar-binding-entry","library_version":"0.1","loss_record_contribution":{"form":"literal","value":{"entries":[]}},"param_names":["s","out"],"param_types":["java.lang.String","java.lang.StringBuilder"],"return_type":"()","signature_shape_cid":"blake3-512:197d5fa4093260a283c305b83fb46831349ef42823339cad564ce73a7a22d6005b3a37f7c74e41696c02ba11b82300541b9fc68766dbdd47e30b053455e3c1f9","source_function_name":"encode_string","target_l