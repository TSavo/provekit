¦dkindgcatalogdnamekir-documentfsignerx4ed25519:IVL40Zt5HSRFMkLhXy6rbLfP+ntqXtMAl5YOBpiB2xI=gmembersŻxŗblake3-512:09b7b626b70139acda1ef8c56db0a793ff6d8dd551c9602804e8ee79e5668372bd7303e167524b0f2625d7201a39513172569f86f03c9626030e5530119275eaY’{"body":{"body_source":{"body_text":"    @ProveKitSugar(\u000a        concept = \"concept:rfc8785-jcs-encode-value\",\u000a        library = \"provekit-rfc8785-jcs-java\",\u000a        family = \"concept:family:json-canonicalization\",\u000a        version = \"0.1\",\u000a        loss = {}\u000a    )\u000a    public static void encode_value(JsonNode v, StringBuilder out) {\u000a        if (v == null || v.isNull()) {\u000a            out.append(\"null\");\u000a        } else if (v.isBoolean()) {\u000a            out.append(v.booleanValue() ? \"true\" : \"false\");\u000a        } else if (v.isNumber()) {\u000a            // RFC 8785 uses ECMA-262 number serialization. Java's\u000a            // double-to-string is close but not identical; for now use the\u000a            // textual form Jackson chose. (Full ECMA-262 conformance is a\u000a            // separate loss dimension ŌĆö declared in the rust sister's\u000a            // future when minted.)\u000a            out.append(v.asText());\u000a        } else if (v.isTextual()) {\u000a            encode_string(v.asText(), out);\u000a        } else if (v.isArray()) {\u000a            out.append('[');\u000a            boolean first = true;\u000a            for (JsonNode child : v) {\u000a                if (!first) out.append(',');\u000a                encode_value(child, out);\u000a                first = false;\u000a            }\u000a            out.append(']');\u000a        } else if (v.isObject()) {\u000a            // RFC 8785 requires keys sorted by code-point order (after parsing\u000a            // unescape).\u000a            List<String> keys = new ArrayList<>();\u000a            Iterator<String> it = v.fieldNames();\u000a            while (it.hasNext()) keys.add(it.next());\u000a            Collections.sort(keys);\u000a            out.append('{');\u000a            boolean first = true;\u000a            for (String k : keys) {\u000a                if (!first) out.append(',');\u000a                encode_string(k, out);\u000a                out.append(':');\u000a                encode_value(v.get(k), out);\u000a                first = false;\u000a            }\u000a            out.append('}');\u000a        }\u000a    }\u000a","file":"src/main/java/org/provekit/shim/rfc8785_jcs_java/RFC8785JcsShim.java","source_cid":"blake3-512:0d7862bcb72a513c70ed090fddf41d98d18fd2cb0681348511bc1d5dba9efe932ecf73063155bab98062440e27ca5991fcb24e05bf4178a94a8a48c944ecba12","span":{"end_col":5,"end_line":105,"start_col":4,"start_line":57}},"concept_name":"concept:rfc8785-jcs-encode-value","family":"concept:family:json-canonicalization","kind":"library-sugar-binding-entry","library_version":"0.1","loss_record_contribution":{"form":"literal","value":{"entries":[]}},"param_names":["v","out"],"param_types":["JsonNode","java.lang.StringBuilder"],"return_type":"()","signature_shape_cid":"blake3-512:d674b6b3d653b90bb3ed27df52cf64aa370c59f9033d0c5b45fb6805e7614a486a78c7e20121e34b38e8bed448364c924eb2ebaa95afe3660857d97992f88840","source_function_name":"encode_value","target_language":"java","target_library_tag":"provekit-rfc8785-jcs-java","term_shape":{"args":[{"args":[{},{"args":[],"concept_name":"concept:seq","op_cid":"blake3-512:2f4f01ae873fcd3d57990ecd94e24caaa3ce1cbd5baf4347b21fe8625750bd4b30e2f92b8415e4595ec637d3aa7f511d42c006d587ee1cf5fe8b264df39f1504"},{"args":[{},{"args":[],"concept_name":"concept:seq","op_cid":"blake3-512:2f4f01ae873fcd3d57990ecd94e24caaa3ce1cbd5baf4347b21fe8625750bd4b30e2f92b8415e4595ec637d3aa7f511d42c006d587ee1cf5fe8b264df39f1504"},{"args":[{},{"args":[],"concept_name":"concept:seq","op_cid":"blake3-512:2f4f01ae873fcd3d57990ecd94e24caaa3ce1cbd5baf4347b21fe8625750bd4b30e2f92b8415e4595ec637d3aa7f511d42c006d587ee1cf5fe8b264df39f1504"}