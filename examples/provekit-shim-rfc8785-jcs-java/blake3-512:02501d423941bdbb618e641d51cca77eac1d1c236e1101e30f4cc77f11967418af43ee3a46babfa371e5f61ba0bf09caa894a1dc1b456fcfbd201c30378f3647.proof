(v.isNumber()) {\u000a            // RFC 8785 uses ECMA-262 number serialization. Java's\u000a            // double-to-string is close but not identical; for now use the\u000a            // textual form Jackson chose. (Full ECMA-262 conformance is a\u000a            // separate loss dimension ŌĆö declared in the rust sister's\u000a            // future when minted.)\u000a            out.append(v.asText());\u000a        } else if (v.isTextual()) {\u000a            encode_string(v.asText(), out);\u000a        } else if (v.isArray()) {\u000a            out.append('[');\u000a            boolean first = true;\u000a            for (JsonNode child : v) {\u000a                if (!first) out.append(',');\u000a                encode_value(child, out);\u000a                first = false;\u000a            }\u000a            out.append(']');\u000a        } else if (v.isObject()) {\u000a            // RFC 8785 requires keys sorted by code-point order (after parsing\u000a            // unescape).\u000a            List<String> keys = new ArrayList<>();\u000a            Iterator<String> it = v.fieldNames();\u000a            while (it.hasNext()) keys.add(it.next());\u000a            Collections.sort(keys);\u000a            out.append('{');\u000a            boolean first = true;\u000a            for (String k : keys) {\u000a                if (!first) out.append(',');\u000a                encode_string(k, out);\u000a                out.append(':');\u000a                encode_value(v.get(k), out);\u000a                first = false;\u000a            }\u000a            out.append('}');\u000a        }\u000a    ","file":"src/main/java/org/provekit/shim/rfc8785_jcs_java/RFC8785JcsShim.java","source_cid":"blake3-512:f507ca8b6a2d48de020bd7c6e3d3e2e65cf9637d8a1c5d86240c3e8c8de7c36a6a3b3fc828ba7fa0c2e892090d76e53bca63f7cf50f8c0a9aa77fc27453e310d","span":{"end_col":5,"end_line":112,"start_col":4,"start_line":59}},"concept_name":"concept:rfc8785-jcs-encode-value","family":"concept:family:json-