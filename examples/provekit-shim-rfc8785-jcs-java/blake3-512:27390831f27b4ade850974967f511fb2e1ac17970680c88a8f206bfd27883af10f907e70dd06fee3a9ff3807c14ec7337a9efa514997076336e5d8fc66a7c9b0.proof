¦dkindgcatalogdnamekir-documentfsignerx4ed25519:IVL40Zt5HSRFMkLhXy6rbLfP+ntqXtMAl5YOBpiB2xI=gmembersŻxŗblake3-512:adfb1321428d011c8e602c2804e2ccb81ffdbed08e1579d1775dc8714d79e3c0cd651cc191dee9b1ea4634149dda14be539627f143acf49e627a99017a79014fY?r{"body":{"body_source":{"body_text":"        if (v == null || v.isNull()) {\u000a            out.append(\"null\");\u000a        } else if (v.isBoolean()) {\u000a            out.append(v.booleanValue() ? \"true\" : \"false\");\u000a        } else if (v.isNumber()) {\u000a            // RFC 8785 uses ECMA-262 number serialization. Java's\u000a            // double-to-string is close but not identical; for now use the\u000a            // textual form Jackson chose. (Full ECMA-262 conformance is a\u000a            // separate loss dimension ŌĆö declared in the rust sister's\u000a            // future when minted.)\u000a            out.append(v.asText());\u000a        } else if (v.isTextual()) {\u000a            encode_string(v.asText(), out);\u000a        } else if (v.isArray()) {\u000a            out.append('[');\u000a            boolean first = true;\u000a            for (JsonNode child : v) {\u000a                if (!first) out.append(',');\u000a                encode_value(child, out);\u000a                first = false;\u000a            }\u000a            out.append(']');\u000a        } else if (v.isObject()) {\u000a            // RFC 8785 requires keys sorted by code-point order (after parsing\u000a            // unescape).\u000a            List<String> keys = new ArrayList<>();\u000a            Iterator<String> it = v.fieldNames();\u000a            while (it.hasNext()) keys.add(it.next());\u000a            Collections.sort(keys);\u000a            out.append('{');\u000a            boolean first = true;\u000a            for (String k : keys) {\u000a                if (!first) out.append(',');\u000a                encode_string(k, out);\u000a                out.append(':');\u000a                encode_value(v.get(k), out);\u000a                first = false;\u000a            }\u000a            out.append('}');\u000a        }\u000a    ","file":"src/main/java/org/provekit/shim/rfc8785_jcs_java/RFC8785JcsShim.java","source_cid":"blake3-512:0d7862bcb72a513c70ed090fddf41d98d18fd2cb0681348511bc1d5dba9efe932ecf73063155bab98062440e27ca5991fcb24e05bf4178a94a8a48c944ecba12","span":{"end_col":5,"end_line":105,"start_col":4,"start_line":57}},"concept_name":"concept:rfc8785-jcs-encode-value","family":"concept:family:json-canonicalization","kind":"library-sugar-binding-entry","library_version":"0.1","loss_record_contribution":{"form":"literal","value":{"entries":[]}},"param_names":["v","out"],"param_sort_cids":["blake3-512:702064722b23410fde0d1fd7afac165bf5914441d67abe1e19d63b0e8fe8117296d2677cc721ad096b8b3bb82d178af699bf14fd70bfb18756c5bed6f4434108","blake3-512:37d8efe0ce6321d1a16f80aa06cbdf056c846b8a99613731e8d64d9581af61bc517fd8c87daaff2c817585a7dfd763e09ed729fdc71d25fe16fb1b2e6ca33534"],"param_types":["JsonNode","java.lang.StringBuilder"],"return_sort_cid":"blake3-512:47682b09e5dba71f563db6249c6cb352f7d540986dc7f4cd8d4fb1aa6d9a503064033ee3eb9f36ee6f9e000f700f2f030ebfcfe2b2b8b7e81a345b0d56551f1b","return_type":"()","signature_shape_cid":"blake3-512:d674b6b3d653b90bb3ed27df52cf64aa370c59f9033d0c5b45fb6805e7614a486a78c7e20121e34b38e8bed448364c924eb2ebaa95afe3660857d97992f88840","source_function_name":"encode_value","target_language":"java","target_library_tag":"provekit-rfc8785-jcs-java","term_shape":{"args":[{"args":[{},{"args":[{"args":[{"kind":"method","text":"out.append"},{"kind":"literal","value":"null"}],"concept_name":"concept:call","op_cid":"blake3-512:fa2fd7c6f33492f270282faf69a89e21bb9988d8d0d9678d253c19aa00a977bf1158396b870f2160b718835c6189b51a97b848af8946d43e4244728f0b7e870c"}],"concept_name":"concept:seq","op_cid":"blake3-512:2f4f01ae873fcd3d57990ecd94e24caaa3ce1cbd5baf4347b21fe8625750bd4b30e2f92b8415e4595ec637d3aa7f511d42c006d587ee1cf5fe8b264df39f1504"},{"args":[{"args":[{"kind":"meth