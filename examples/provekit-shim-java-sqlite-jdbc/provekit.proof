ndling-model\"}\u000a    )\u000a    public static long stmtInsert(PreparedStatement stmt) throws SQLException {\u000a        stmt.executeUpdate();\u000a        try (ResultSet rs = stmt.getGeneratedKeys()) {\u000a            if (rs.next()) return rs.getLong(1);\u000a            return -1L;\u000a        }\u000a    }\u000a","file":"src/main/java/org/provekit/shim/sqlite_jdbc/SqliteJdbcShim.java","source_cid":"blake3-512:015a5f70619c28785a745ee94bb92eaaebfa5589a8ee2a926b6cf4673ed94424db46d057d230b14fee423016cb2d27f922b9f3be66816739d8b30e1f4b74095c","span":{"end_col":5,"end_line":259,"start_col":4,"start_line":248}},"concept_name":"concept:insert-and-get-id","kind":"library-sugar-binding-entry","loss_record_contribution":{"form":"literal","value":{"entries":["sync-vs-async","id-column-discovery","error-handling-model"]}},"param_names":["stmt"],"param_types":["java.sql.PreparedStatement"],"return_type":"long","signature_shape_cid":"blake3-512:6df81b040a045d98f080b1e01a947686011100db8a1418566802e0d23b3c4f349aa20d0f9c3fb7e6b4be1a077b1968bc7d865507480222b2b976458f68bf250b","source_function_name":"stmtInsert","target_language":"java","target_library_tag":"sqlite-jdbc","term_shape":{"args":[],"concept_name":"concept:seq","op_cid":"blake3-512:2f4f01ae873fcd3d57990ecd94e24caaa3ce1cbd5baf4347b21fe8625750bd4b30e2f92b8415e4595ec637d3aa7f511d42c006d587ee1cf5fe8b264df39f1504"},"term_shape_cid":"blake3-512:8932633001ef50a703f31ae95992685a3c12b4fc1f6ef88636c7d0f4654a23c6acc6098c613f96696fa100f4abf5051242f531df2ded1be9a9c0568d4f11a52d"},"header":{"bodySourceCid":"blake3-512:015a5f70619c28785a745ee94bb92eaaebfa5589a8ee2a926b6cf4673ed94424db46d057d230b14fee423016cb2d27f922b9f3be66816739d8b30e1f4b74095c","conceptName":"concept:insert-and-get-id","kind":"library-sugar-binding-entry","signatureShapeCid":"blake3-512:6df81b040a045d98f080b1e01a947686011100db8a1418566802e0d23b3c4f349aa20d0f9c3fb7e6b4be1a077b1968bc7d865507480222b2b976458f68bf250b","targetLanguage":"java","targetLibraryTag":"sqlit