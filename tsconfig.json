{
  "compilerOptions": {
    "rootDir": "implementations/typescript/src",
    "outDir": "dist",
    "module": "node20",
    "target": "es2022",
    "moduleResolution": "nodenext",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["implementations/typescript/src/**/*"],
  "exclude": ["implementations/typescript/src/**/*.test.ts"]
}
