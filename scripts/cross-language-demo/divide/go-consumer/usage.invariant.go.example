// Go consumer's invariant file.
//
// Composes against the C++ library's contract H_divide via cgo binding's
// propertyHash. The Go kit's lifter sees the call to `divide` (through
// SafeDivide), looks up its registry contract, and verifies the
// precondition at every Go callsite.

package divide_consumer

import (
    "github.com/provekit/ir"
)

func init() {
    ir.Property("SafeDivideUpholdsPrecondition",
        ir.ForAll(ir.Int, func(n ir.Term) ir.Formula {
            return ir.ForAll(ir.Int, func(d ir.Term) ir.Formula {
                return ir.Implies(
                    ir.NotEqual(d, ir.Const(0)),
                    ir.Apply("SafeDivide", n, d),
                )
            })
        }),
    )
}
