// C++ consumer of the C++ divide library: direct call.
//
// Native source contract surface:
// - the guard establishes the library precondition
// - the C++ lifter derives the wrapper obligation from this function body

#include "divide.h"
#include <stdexcept>

int safe_divide(int n, int d) {
    if (d == 0) {
        throw std::runtime_error("denominator must not be zero");
    }
    return divide(n, d);
}
