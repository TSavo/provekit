// C++ consumer's invariant file (in the same kit as the library).
//
// Composes against the same library contract H_divide. The C++ kit's
// lifter sees the call from `safe_divide` to `divide`, looks up the
// library's contract, verifies the precondition.

#include "usage.h"
#include "divide.h"
#include <provekit/ir.hpp>

PROVEKIT_PROPERTY("safeDivideUpholdsPrecondition",
    forall<Int>(n => forall<Int>(d =>
        implies(d != 0, safe_divide(n, d) == divide(n, d))
    ))
)
