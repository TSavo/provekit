// Rust consumer of the C++ divide library, via FFI.
//
// Native source contract surface:
// - the Result error branch establishes the non-zero precondition
// - a Rust lifter reads the function body and existing native assertions or
//   contracts attributes when present; no sibling DSL file is needed

use std::error::Error;

extern "C" {
    fn divide(n: i32, d: i32) -> i32;
}

pub fn safe_divide(n: i32, d: i32) -> Result<i32, Box<dyn Error>> {
    if d == 0 {
        return Err("denominator must not be zero".into());
    }
    Ok(unsafe { divide(n, d) })
}
