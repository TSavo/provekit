// Rust consumer's invariant file.
//
// Composes against the C++ library's contract H_divide via the FFI
// binding's propertyHash. The Rust kit's lifter sees the call to
// `divide`, looks up its registry contract (provided by the C++ kit's
// published proof DAG), and verifies the precondition is established
// at every Rust callsite.

use provekit_ir::{property, forall, implies, Int};
use crate::usage::safe_divide;

property!("safe_divide_upholds_precondition",
    forall!(n: Int => forall!(d: Int =>
        implies(d != 0, safe_divide(n, d).is_ok())
    ))
);
