// Cross-language demo: C++ native source form.
//
// The C++ source lifter reads the function body and native assertions. The
// guard excludes signed overflow so the canonical postcondition can match the
// Rust, Go, and TypeScript versions.

#include <cassert>
#include <cstdint>
#include <limits>
#include <stdexcept>

std::int64_t successor(std::int64_t x) {
    if (x == std::numeric_limits<std::int64_t>::max()) {
        throw std::overflow_error("successor is defined below INT64_MAX");
    }
    return x + 1;
}

void successor_is_greater_examples() {
    for (std::int64_t x : {-2, -1, 0, 1, 41}) {
        assert(successor(x) > x);
    }
}
