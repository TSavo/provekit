// Cross-language demo: Rust native source form.
//
// The Rust lifter consumes established native contract attributes. No sibling
// contract DSL file is authored; the obligation lives on the function.

use contracts::{ensures, requires};

#[requires(x < i64::MAX)]
#[ensures(ret > x)]
pub fn successor(x: i64) -> i64 {
    x + 1
}
