node_modules/
dist/
*.smt2
.worktrees/

# Vendored BLAKE3 build artifacts (compiled into Side B + Side A static libs)
tools/blake3-vendored/*.o

# Bazel convenience symlinks at the workspace root.
/bazel-*
.bazelrc.local

# Build-derived artifacts — machine-specific paths, regenerated by analyze/derive/verify.
# Only .neurallog/principles/ (learned knowledge) is intended to be versioned.
.neurallog/contracts/
.neurallog/contexts/
.neurallog/observations/
.neurallog/harnesses/
.neurallog/judge-cache/
.neurallog/lessons/
.neurallog/witnesses/
.neurallog/test-cache/
.neurallog/graph.json
.neurallog/report.json
.neurallog/derivation.json
.neurallog/classification.json
.neurallog/neurallog.db
.neurallog/neurallog.db-journal
.neurallog/neurallog.db-wal
.neurallog/neurallog.db-shm

# Fix-loop run artifacts — per-run state and scratch (regenerated by analyze).
# Same shape as .neurallog/ above. Only .provekit/principles/ (learned
# knowledge) is intended to be versioned.
.provekit/fix-loop-*.log
.provekit/fuzz-runs/
.provekit/contexts/
.provekit/contracts/
.provekit/observations/
.provekit/graph.json
.provekit/report.json
.provekit/derivation.json
.provekit/provekit.db
.provekit/provekit.db-journal
.provekit/provekit.db-wal
.provekit/provekit.db-shm
.provekit/prompts.db
.provekit/prompts.db-journal
.provekit/prompts.db-wal
.provekit/prompts.db-shm
.provekit/or-chain-mining-results.json
# Harvest staging — discovered principles awaiting validation/promotion.
# Once promoted to .provekit/principles/ they become source-controlled.
.provekit/harvest/staging/
.provekit/harvest/harvest.db
.provekit/harvest/harvest.db-shm
.provekit/harvest/harvest.db-wal
prompts.db
# Verify-cache (step 6 of the standing-invariant runtime).
# Build artifact: deletable, rebuilds on next run.
.provekit/cache/

# Foundation private keys. The .pub counterpart IS committed; the
# .priv file is gitignored so the v0 procedure mirrors what v1 will
# require (an HSM-generated seed that must never be committed).
.provekit/keys/*.priv

# Cargo build output for the foundation-keygen tool.
tools/foundation-keygen/target/

# Cargo build output for the recompute-spec-cids tool.
tools/recompute-spec-cids/target/

# Rust workspace target dir.
implementations/rust/target/

# C++ orchestrator binary output (rebuilt by tools/build-cpp-self-contracts.sh).
implementations/cpp/target/

# C# bin/obj dirs (per-project, regenerated by `dotnet build`).
implementations/csharp/**/bin/
implementations/csharp/**/obj/

# Maven target dirs for the Java kit (per-module, regenerated by `mvn package`).
implementations/java/**/target/

# Go orchestrator binary output (built per-module).
implementations/go/provekit-self-contracts/mint-go-self-contracts
implementations/go/provekit-lift-go-tests/provekit-lift-go

# Claude IDE worktrees.
.claude/

# Self-contract .proof files. The CID is the filename, but these are
# build artifacts of `provekit mint` runs; the canonical .proof lives in
# the protocol/ tree, not at the implementations/<lang>/ root.
implementations/*/blake3-512:*.proof
/blake3-512:*.proof
**/*.proof

# Self-lift experiment artifacts ARE checked in: the .proof is the
# minted output of running `provekit-lift` against a first-party crate
# and serves as the durable record of what the auto-lifter reaches on
# real source. Rebuild with `make self-lift-<crate>`.
!.provekit/self-lifts/**/*.proof

# Zig build artifacts
implementations/zig/**/.zig-cache/
implementations/zig/**/zig-out/
