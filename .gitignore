.neurallog/neurallog.db-wal
.neurallog/neurallog.db-shm

# Fix-loop run artifacts: per-run state and scratch (regenerated by analyze).
# Same shape as .neurallog/ above. Only .sugar/principles/ (learned
# knowledge) is intended to be versioned.
.sugar/fix-loop-*.log
.sugar/fuzz-runs/
.sugar/contexts/
.sugar/contracts/
.sugar/observations/
.sugar/graph.json
.sugar/report.json
.sugar/derivation.json
.sugar/runs/
.sugar/sugar.db
