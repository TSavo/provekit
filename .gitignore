node_modules/
dist/
*.smt2
.worktrees/

# Bazel convenience symlinks at the workspace root.
/bazel-*
.bazelrc.local

# Build-derived artifacts — machine-specific paths, regenerated by analyze/derive/verify.
# Only .neurallog/principles/ (learned knowledge) is intended to be versioned.
.neurallog/contracts/
.neurallog/contexts/
.neurallog/observations/
.neurallog/harnesses/
.neurallog/judge-cache/
.neurallog/lessons/
.neurallog/witnesses/
.neurallog/test-cache/
.neurallog/graph.json
.neurallog/report.json
.neurallog/derivation.json
.neurallog/classification.json
.neurallog/neurallog.db
.neurallog/neurallog.db-journal
.neurallog/neurallog.db-wal
.neurallog/neurallog.db-shm

# Fix-loop run artifacts — per-run state and scratch (regenerated by analyze).
# Same shape as .neurallog/ above. Only .provekit/principles/ (learned
# knowledge) is intended to be versioned.
.provekit/fix-loop-*.log
.provekit/fuzz-runs/
.provekit/contexts/
.provekit/contracts/
.provekit/observations/
.provekit/graph.json
.provekit/report.json
.provekit/derivation.json
.provekit/provekit.db
.provekit/provekit.db-journal
.provekit/provekit.db-wal
.provekit/provekit.db-shm
.provekit/prompts.db
.provekit/prompts.db-journal
.provekit/prompts.db-wal
.provekit/prompts.db-shm
.provekit/or-chain-mining-results.json
# Harvest staging — discovered principles awaiting validation/promotion.
# Once promoted to .provekit/principles/ they become source-controlled.
.provekit/harvest/staging/
.provekit/harvest/harvest.db
.provekit/harvest/harvest.db-shm
.provekit/harvest/harvest.db-wal
prompts.db
# Verify-cache (step 6 of the standing-invariant runtime).
# Build artifact: deletable, rebuilds on next run.
.provekit/cache/

# Foundation private keys. The .pub counterpart IS committed; the
# .priv file is gitignored so the v0 procedure mirrors what v1 will
# require (an HSM-generated seed that must never be committed).
.provekit/keys/*.priv

# Cargo build output for the foundation-keygen tool.
tools/foundation-keygen/target/
