.sugar/sugar.db-shm
.sugar/prompts.db
.sugar/prompts.db-journal
.sugar/prompts.db-wal
.sugar/prompts.db-shm
.sugar/or-chain-mining-results.json
# Harvest staging: discovered principles awaiting validation/promotion.
# Once promoted to .sugar/principles/ they become source-controlled.
.sugar/harvest/staging/
.sugar/harvest/harvest.db
.sugar/harvest/harvest.db-shm
.sugar/harvest/harvest.db-wal
prompts.db
# Verify-cache (step 6 of the standing-invariant runtime).
# Build artifact: deletable, rebuilds on next run.
.sugar/cache/

# Foundation private keys. The .pub counterpart IS committed; the
# .priv file is gitignored so the v0 procedure mirrors what v1 will
# require (an HSM-generated seed that must never be committed).
.sugar/keys/*.priv

# Cargo build output for the foundation-keygen tool.
tools/foundation-keygen/target/

# Cargo build output for the recompute-spec-cids tool.
tools/recompute-spec-cids/target/

# Rust workspace target dir.
implementations/rust/target/

# C lifter test/plugin binaries.
implementations/c/sugar-lift/bin/


# C++ orchestrator binary output (rebuilt by tools/build-cpp-self-contracts.sh).
implementations/cpp/target/

# C# bin/obj dirs (per-project, regenerated by `dotnet build`).
implementations/csharp/**/bin/
implementations/csharp/**/obj/

# Maven target dirs for the Java kit (per-module, regenerated by `mvn package`).
implementations/java/**/target/

# Go orchestrator binary output (built per-module).
implementations/go/sugar-self-contracts/mint-go-self-contracts
implementations/go/sugar-lift-go-tests/sugar-lift-go

# Claude IDE worktrees.
.claude/

# Self-contract .proof files. The CID is the filename, but these are
# build artifacts of `sugar mint` runs; the canonical .proof lives in
# the protocol/ tree, not at the implementations/<lang>/ root.
implementations/*/blake3-512:*.proof
/blake3-512:*.proof
**/*.proof

# Self-lift experiment artifacts ARE checked in: the .proof is the
# minted output of running `sugar-lift` against a first-party crate
# and serves as the durable record of what the auto-lifter reaches on
# real source. Rebuild with `make self-lift-<crate>`.
!.sugar/self-lifts/**/*.proof

# Example shim proof envelopes are checked in. Each examples/<shim>/sugar.proof
# is the minted output of running `sugar mint` against that shim and serves as
# the durable signed record of that shim's surface model. Rebuild with
# `sugar mint --project examples/<shim>`.
!examples/**/*.proof

# Foundation-baseline catalogs ARE checked in: each per-language
# `.sugar/baselines/<lang>-baseline-v<N>.proof` is the foundation-signed
# advisory catalog of std-library predicates (per
# `docs/contributing/baseline-catalog-rubric.md`). Rebuild via the
# language-specific mint binary (e.g.
# `cargo run -p sugar-baseline-rust-std --bin mint-rust-std-baseline`).
!.sugar/baselines/*.proof

# Zig build artifacts
implementations/zig/**/.zig-cache/
implementations/zig/**/zig-out/

# Ruby native extension build/copy artifacts regenerated from vendored sources.
implementations/ruby/ext/sugar_blake3/Makefile
implementations/ruby/ext/sugar_blake3/*.o
implementations/ruby/ext/sugar_blake3/*.bundle
implementations/ruby/ext/sugar_blake3/*.bundle.dSYM/
implementations/ruby/ext/sugar_blake3/blake3.c
implementations/ruby/ext/sugar_blake3/blake3_portable.c
implementations/ruby/ext/sugar_blake3/blake3_dispatch.c
implementations/ruby/ext/sugar_blake3/blake3.h
implementations/ruby/ext/sugar_blake3/blake3_impl.h

# Local dev clones / git worktrees, never intended as submodules (no .gitmodules
# entry ever existed). Both were accidentally committed as gitlinks in 226913c60,
# which broke `git submodule` during CI checkout. Gitlinks removed; ignore the
# on-disk dirs so they don't reappear as untracked.
/sugar-warnings/
/sugar-worktrees/
