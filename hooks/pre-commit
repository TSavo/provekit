#!/usr/bin/env bash
set -euo pipefail

repo="$(git rev-parse --show-toplevel)"
cd "$repo"

manifest="$repo/implementations/rust/Cargo.toml"
if [ ! -f "$manifest" ]; then
  echo "pre-commit: missing Rust workspace manifest: $manifest" >&2
  exit 1
fi

staged=()
while IFS= read -r -d '' path; do
  staged+=("$path")
done < <(git diff --cached --name-only -z --diff-filter=ACMR -- '*.rs')

if [ "${#staged[@]}" -eq 0 ]; then
  exit 0
fi

format_paths=()
restage_paths=()
for path in "${staged[@]}"; do
  if [ ! -f "$path" ]; then
    continue
  fi
  if ! git diff --quiet -- "$path"; then
    echo "pre-commit: skipping partially staged Rust file: $path" >&2
    continue
  fi
  case "$path" in
    implementations/rust/*)
      format_paths+=("${path#implementations/rust/}")
      restage_paths+=("$path")
      ;;
    *)
      echo "pre-commit: skipping Rust file outside the cargo workspace: $path" >&2
      ;;
  esac
done

if [ "${#format_paths[@]}" -eq 0 ]; then
  exit 0
fi

# cargo fmt cannot resolve targets for file args via --manifest-path at the
# virtual workspace root; run from the workspace dir with relative paths.
(cd "$repo/implementations/rust" && cargo fmt -- "${format_paths[@]}")
git add -- "${restage_paths[@]}"
